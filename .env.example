# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth
AUTH_SECRET=paktech-auth-secret-change-in-production

# Google OAuth (optional — enable Google Sign-In)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Store Admin Credentials
ADMIN_EMAIL=admin@paktech.pk
ADMIN_PASSWORD=admin123
ADMIN_SECRET=paktech-admin-secret-change-in-production

# Admin App (separate app) - points to store API
ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_STORE_API=http://localhost:3000
