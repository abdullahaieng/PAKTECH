rules_version = '2';

// PakTech Firestore Security Rules
// - Public Read: Allowed for storefront data (products, categories, settings, etc.) so the UI can load them.
// - User Access: Users can read/write their own profile and read their own orders.
// - Public Write/Create: Visitors can submit contact messages and create orders.
// - Admin/Server: The Next.js server uses firebase-admin (Admin SDK), which bypasses these rules, allowing full CRUD for the Admin Panel.

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Catalog & Storefront Data — Readable by anyone, writeable only by admin/server
    match /products/{productId} {
      allow read: if true;
      allow write: if false; // Admin SDK bypasses this
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    match /faqs/{faqId} {
      allow read: if true;
      allow write: if false;
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if false;
    }

    match /teamMembers/{memberId} {
      allow read: if true;
      allow write: if false;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /meta/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /coupons/{code} {
      allow read: if true; // Allowed so UI can validate discount codes on checkout
      allow write: if false;
    }

    // 2. User Profiles — Users can read and update their own profiles
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 3. Orders — Anyone can place an order (guest/logged-in), users can read their own orders
    match /orders/{orderId} {
      allow create: if true;
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        request.auth.token.email == resource.data.shippingAddress.email
      );
      allow update, delete: if false; // Only admin/server can update order status or delete orders
    }

    // 4. Contact Messages — Anyone can submit a message; only admin/server can read/manage them
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // 5. Password Reset Tokens — Server-only for security
    match /passwordResetTokens/{tokenId} {
      allow read, write: if false;
    }

    // Default fallback: Deny anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}